{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Node Graph Tauri",
  "version": "0.1.0",
  "identifier": "com.latentarts.guexamples.nodegraph-tauri",
  "build": {
    "frontendDist": "../dist",
    "beforeDevCommand": "make wasm",
    "beforeBuildCommand": "make wasm"
  },
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "main",
        "title": "Node Graph Tauri",
        "width": 1440,
        "height": 960,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
